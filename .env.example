# Root env for `docker compose up` — copy to .env and edit.

# Database password (compose passes it to both postgres and the API)
POSTGRES_PASSWORD=change-me-db-password

# JWT secrets — REQUIRED. Use long random strings in production.
JWT_ACCESS_SECRET=change-me-long-random-string-1
JWT_REFRESH_SECRET=change-me-long-random-string-2

# Public URLs (change to your domain when deploying to a server)
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# true when client & API are on different HTTPS domains
COOKIE_SECURE=false

# Optional: real Gemini parsing in the AI service (blank = built-in NLP)
GEMINI_API_KEY=

# ---- All optional: real integrations (blank = built-in simulators) ----

# Public URL of the API (needed by Telegram/Viber webhooks + payment callbacks)
PUBLIC_API_URL=

# "Sign in with Google" — one Client ID from console.cloud.google.com
GOOGLE_CLIENT_ID=

# SSLCOMMERZ hosted checkout — free sandbox from developer.sslcommerz.com
SSLCZ_STORE_ID=
SSLCZ_STORE_PASSWD=

# Cloudinary product photo uploads (Dashboard ▸ Settings ▸ API keys ▸
# "API environment variable"). Blank = uploads disabled.
CLOUDINARY_URL=

# Durable webhook queue. In docker-compose a redis service is provided, so this
# defaults to redis://redis:6379. Blank = inline processing.
REDIS_URL=

# Database-level tenant isolation via Row-Level Security. Set true only AFTER
# applying server/prisma/rls.sql. Default false = app-level scoping.
RLS_ENABLED=false

# bKash Tokenized Checkout sandbox — from developer.bka.sh
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# Meta (Messenger/Instagram/WhatsApp) — from developers.facebook.com
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
