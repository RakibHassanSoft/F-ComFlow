# Copy to .env  (never commit .env itself)

# Real Gemini order parsing. Set your key to make chat extraction use Google
# Gemini (get one free at https://aistudio.google.com/apikey). Without it, the
# built-in rule-based NLP parser is used — the demo works either way.
GEMINI_API_KEY=

# Which Gemini model to call. Gemini 1.x/2.0 are retired (they 404). Default is
# a current stable flash model; bump this when Google releases a newer one.
GEMINI_MODEL=gemini-2.5-flash

PORT=8000
