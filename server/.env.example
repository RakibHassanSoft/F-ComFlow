# Copy this file to .env  (never commit .env itself)

# PostgreSQL — matches docker-compose.yml defaults
DATABASE_URL="postgresql://fcomflow:fcomflow@localhost:5432/fcomflow"

# JWT secrets — change these in production!
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Server
PORT=4000
CLIENT_URL="http://localhost:3000"

# FastAPI AI service (parse + risk model). Leave empty to use the built-in
# TypeScript fallback engines — everything still works without it.
AI_SERVICE_URL="http://localhost:8000"

# Set to true when client & API are served from different HTTPS domains
COOKIE_SECURE=false

# ---- REAL Meta/WhatsApp integration (see docs/CONNECT_CHANNELS.md) ----
# Any secret string; paste the same value in the Meta app webhook setup
META_VERIFY_TOKEN=""
# From the Meta app dashboard -> Settings -> Basic
META_APP_ID=""
META_APP_SECRET=""

# Public https URL of this API (needed by Telegram/Viber webhooks)
PUBLIC_API_URL=""

# "Sign in with Google" — OAuth Client ID from console.cloud.google.com
# (Web application type; also set NEXT_PUBLIC_GOOGLE_CLIENT_ID in client/.env.local)
GOOGLE_CLIENT_ID=""

# Redis durable webhook queue. Blank = inline processing (no Redis needed).
# Set to enable the queue + background worker, e.g. redis://localhost:6379
REDIS_URL=""

# Database-level tenant isolation (Row-Level Security). false = app-level
# scoping only. Set true AFTER applying prisma/rls.sql to your database.
RLS_ENABLED="false"

# Cloudinary product photo uploads (Dashboard ▸ Settings ▸ API keys ▸
# "API environment variable"). Blank = uploads disabled, UI falls back to a
# manual image-URL field.
CLOUDINARY_URL=""

# Email channel: SMTP for outbound replies + token for the inbound webhook
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
EMAIL_WEBHOOK_TOKEN=""

# Real courier tracking (blank = sandbox mocks; see docs/COURIERS.md)
PATHAO_BASE_URL=""
PATHAO_CLIENT_ID=""
PATHAO_CLIENT_SECRET=""
PATHAO_USERNAME=""
PATHAO_PASSWORD=""
PATHAO_STORE_ID=""
PATHAO_WEBHOOK_SECRET=""
REDX_BASE_URL=""
REDX_ACCESS_TOKEN=""
REDX_PICKUP_STORE_ID=""
REDX_WEBHOOK_TOKEN=""
# Steadfast: sandbox base = https://sandbox.steadfast.com.bd/api/v1 ;
# production (default if blank) = https://portal.packzy.com/api/v1
STEADFAST_BASE_URL=""
STEADFAST_API_KEY=""
STEADFAST_SECRET_KEY=""
COURIER_POLL_MS=""

# Real bKash Tokenized Checkout (sandbox creds from developer.bka.sh).
# Blank = the mock "Simulate payment" flow only, which always works.
BKASH_BASE_URL=""
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""

# Real SSLCOMMERZ hosted checkout (free sandbox: developer.sslcommerz.com).
# One hosted page = cards + bKash + Nagad + Rocket. Blank = button hidden.
SSLCZ_BASE_URL=""
SSLCZ_STORE_ID=""
SSLCZ_STORE_PASSWD=""

# "Sign in with Google" (from console.cloud.google.com). Blank = button hidden.
GOOGLE_CLIENT_ID=""

# --- Other real integrations (not needed for the mock demo) ---
# PATHAO_CLIENT_ID=
# SSLCOMMERZ_STORE_ID=
