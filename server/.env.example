# Copy this file to .env  (never commit .env itself)

# PostgreSQL — matches docker-compose.yml defaults
DATABASE_URL="postgresql://fcomflow:fcomflow@localhost:5432/fcomflow"

# JWT secrets — change these in production!
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Server
PORT=4000
CLIENT_URL="http://localhost:3000"

# FastAPI AI service (parse + risk model). Leave empty to use the built-in
# TypeScript fallback engines — everything still works without it.
AI_SERVICE_URL="http://localhost:8000"

# Set to true when client & API are served from different HTTPS domains
COOKIE_SECURE=false

# ---- REAL Meta/WhatsApp integration (see docs/CONNECT_CHANNELS.md) ----
# Any secret string; paste the same value in the Meta app webhook setup
META_VERIFY_TOKEN=""
# From the Meta app dashboard -> Settings -> Basic
META_APP_ID=""
META_APP_SECRET=""

# Public https URL of this API (needed by Telegram/Viber webhooks)
PUBLIC_API_URL=""

# Email channel: SMTP for outbound replies + token for the inbound webhook
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
EMAIL_WEBHOOK_TOKEN=""

# Real courier tracking (blank = sandbox mocks; see docs/COURIERS.md)
PATHAO_BASE_URL=""
PATHAO_CLIENT_ID=""
PATHAO_CLIENT_SECRET=""
PATHAO_USERNAME=""
PATHAO_PASSWORD=""
PATHAO_STORE_ID=""
PATHAO_WEBHOOK_SECRET=""
REDX_BASE_URL=""
REDX_ACCESS_TOKEN=""
STEADFAST_BASE_URL=""
STEADFAST_API_KEY=""
STEADFAST_SECRET_KEY=""
COURIER_POLL_MS=""

# Real bKash Tokenized Checkout (sandbox creds from developer.bka.sh).
# Blank = the mock "Simulate payment" flow only, which always works.
BKASH_BASE_URL=""
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""

# --- Other real integrations (not needed for the mock demo) ---
# PATHAO_CLIENT_ID=
# SSLCOMMERZ_STORE_ID=
